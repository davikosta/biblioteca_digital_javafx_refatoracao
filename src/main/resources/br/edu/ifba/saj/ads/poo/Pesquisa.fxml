<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="350.0" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifba.saj.ads.poo.PesquisaController">
    <children>
        <Label alignment="CENTER" layoutX="154.0" text="Pesquisa de Livros" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <font>
                <Font size="35.0" />
            </font>
        </Label>

        <Label layoutX="14.0" layoutY="58.0" text="Filtrar por Autor:" AnchorPane.leftAnchor="14.0" />
        <ChoiceBox fx:id="slAutor" layoutX="120.0" layoutY="54.0" prefWidth="170.0" AnchorPane.leftAnchor="120.0" />

        <Label layoutX="305.0" layoutY="58.0" text="ou Categoria:" AnchorPane.leftAnchor="305.0" />
        <ChoiceBox fx:id="slCategoria" layoutX="390.0" layoutY="54.0" prefWidth="196.0" AnchorPane.leftAnchor="390.0" AnchorPane.rightAnchor="14.0" />

        <Button layoutX="500.0" layoutY="90.0" mnemonicParsing="false" onAction="#limparFiltros" text="Limpar Filtros" AnchorPane.rightAnchor="14.0" />

        <TableView fx:id="tbLivros" layoutX="14.0" layoutY="130.0" prefHeight="256.0" prefWidth="572.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="130.0">
            <columns>
                <TableColumn fx:id="clmTitulo" prefWidth="200.0" text="Título" />
                <TableColumn fx:id="clmAutor" prefWidth="150.0" text="Autor" />
                <TableColumn fx:id="clmCategorias" prefWidth="220.0" text="Categorias" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>