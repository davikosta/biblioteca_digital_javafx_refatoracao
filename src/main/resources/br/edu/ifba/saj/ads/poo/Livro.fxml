<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="400.0" prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifba.saj.ads.poo.LivroController">
    <children>
        <Label alignment="CENTER" layoutX="154.0" text="Cadastro de Livros" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <font>
                <Font size="35.0" />
            </font>
        </Label>

        <Label layoutX="14.0" layoutY="48.0" text="Título: " AnchorPane.leftAnchor="14.0" />
        <TextField fx:id="txTitulo" layoutX="80.0" layoutY="44.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="14.0" />

        <Label layoutX="14.0" layoutY="82.0" text="Autor: " AnchorPane.leftAnchor="14.0" />
        <ChoiceBox fx:id="slAutor" layoutX="80.0" layoutY="78.0" prefHeight="25.0" prefWidth="506.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="14.0" />

        <Label layoutX="14.0" layoutY="116.0" text="Categoria:" AnchorPane.leftAnchor="14.0" />
        <ChoiceBox fx:id="slCategoria" layoutX="80.0" layoutY="112.0" prefHeight="25.0" prefWidth="390.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="130.0" />
        <Button layoutX="480.0" layoutY="112.0" mnemonicParsing="false" onAction="#adicionarCategoria" text="Adicionar" AnchorPane.rightAnchor="14.0" />

        <ListView fx:id="lvCategorias" layoutX="80.0" layoutY="145.0" prefHeight="60.0" prefWidth="506.0" AnchorPane.leftAnchor="80.0" AnchorPane.rightAnchor="14.0" />

        <Button defaultButton="true" layoutX="538.0" layoutY="215.0" mnemonicParsing="false" onAction="#salvar" text="Salvar" AnchorPane.rightAnchor="14.0" />

        <TableView fx:id="tbLivros" layoutX="14.0" layoutY="250.0" prefHeight="186.0" prefWidth="572.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="250.0">
            <columns>
                <TableColumn fx:id="clmTitulo" editable="false" prefWidth="200.0" text="Título" />
                <TableColumn fx:id="clmAutor" prefWidth="150.0" text="Autor" />
                <TableColumn fx:id="clmCategorias" prefWidth="220.0" text="Categorias" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</AnchorPane>